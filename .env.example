# Copy this to .env and fill in values before running setup.sh or ralph.sh
# Never commit .env

# Required: Anthropic API key for Claude Code
ANTHROPIC_API_KEY=sk-ant-...

# Required: Git identity for Ralph's commits
GIT_USER_NAME=Ralph
GIT_USER_EMAIL=ralph@yourproject.com

# Required: GitHub token for pushing branches (fine-grained PAT)
# Permissions needed: Contents: write, Pull requests: write
GITHUB_TOKEN=ghp_...

# The GitHub repo in owner/repo format
GITHUB_REPO=juliankmazo/orchid-ralph-hackaton
